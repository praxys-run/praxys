<view class="train-root {{themeClass}}">
  <nav-bar title="{{tr.navTitle}}" theme-class="{{themeClass}}" />

  <scroll-view
    scroll-y="{{true}}"
    refresher-enabled="{{true}}"
    refresher-triggered="{{refreshing}}"
    bindrefresherrefresh="onScrollRefresh"
    class="train-scroll"
  >
    <view class="train-content">

    <block wx:if="{{loading && !hasResponse}}">
      <state-card type="loading" />
      <state-card type="loading" />
    </block>

    <block wx:elif="{{errorMessage}}">
      <state-card type="error" headline="{{tr.failedToLoad}}" detail="{{errorMessage}}" show-retry bindretry="onRetry" />
    </block>

    <block wx:elif="{{hasResponse}}">
      <state-card wx:if="{{!hasAnyData}}" type="empty" headline="{{tr.noData}}" />

      <!-- ═══════════════════════════════════════════════════════════
           DIAGNOSIS · stat strip (4 numbers) + pill switcher (one
           chart at a time) + Coach receipt below. Reading order:
           glance the number → see the matching chart → read the
           coach's interpretation. Same shape as web's PR #280.
           ═══════════════════════════════════════════════════════════ -->
      <block wx:if="{{hasAnyData}}">
        <text class="train-section-eyebrow">{{tr.diagnosis}} · {{diagnosisEyebrow}}</text>

        <!-- Stat strip — 2x2 grid on phone (stacked rows of two,
             columns aligned). Each cell: mono uppercase label, big
             tabular value with optional % unit, mono caption. The
             accent class on .train-stat-value carries the verdict
             tint; volume is intentionally untinted (context number,
             not a verdict). -->
        <view class="train-stats">
          <view
            wx:for="{{cells}}"
            wx:key="id"
            class="train-stat-cell"
          >
            <text class="train-stat-label">{{item.label}}</text>
            <view class="train-stat-row">
              <text class="train-stat-value ts-value {{item.accent}}">{{item.value}}</text>
              <text wx:if="{{item.unit}}" class="train-stat-unit">{{item.unit}}</text>
            </view>
            <text class="train-stat-sub">{{item.sub}}</text>
          </view>
        </view>

        <!-- Pill switcher. Persists active to wx storage so power
             users land on their preferred chart on every visit.
             Zones pill is conditional on at least one zone having
             a target — without it the pill renders inert and
             invites a bug. -->
        <view class="train-pills" role="tablist" aria-label="{{tr.diagnosis}}">
          <view
            class="train-pill {{activePill === 'form' ? 'train-pill--active' : ''}}"
            data-pill="form"
            bindtap="onPickPill"
          >{{tr.pillForm}}</view>
          <view
            wx:if="{{hasZones}}"
            class="train-pill {{activePill === 'zones' ? 'train-pill--active' : ''}}"
            data-pill="zones"
            bindtap="onPickPill"
          >{{tr.pillZones}}</view>
          <view
            class="train-pill {{activePill === 'compliance' ? 'train-pill--active' : ''}}"
            data-pill="compliance"
            bindtap="onPickPill"
          >{{tr.pillCompliance}}</view>
        </view>

        <!-- Active chart pane. One option visible at a time; the
             switcher above flips between them. Each option carries
             its own DataHint countdown copy when the underlying
             window isn't long enough yet. -->
        <view class="train-chart-pane">
          <block wx:if="{{activePill === 'form'}}">
            <line-chart
              wx:if="{{ffSufficient}}"
              canvas-id="train-ctl-atl-tsb"
              height="{{280}}"
              show-zero-line="{{true}}"
              dates="{{ffDates}}"
              series="{{ffSeries}}"
              theme="{{chartTheme}}"
            />
            <view wx:else class="train-data-hint">
              <text class="train-data-hint-message ts-muted">{{ffHintMessage}}</text>
              <text class="train-data-hint-detail ts-muted">{{ffHintDetail}}</text>
            </view>
          </block>

          <block wx:if="{{activePill === 'zones' && hasZones}}">
            <text class="train-zone-section-label">{{zoneSectionLabel}}</text>
            <view
              wx:for="{{zoneRows}}"
              wx:key="name"
              class="train-zonebar"
            >
              <view class="train-zonebar-head">
                <text class="train-zonebar-name">{{item.name}}</text>
                <text class="train-zonebar-value ts-value">{{item.label}}</text>
              </view>
              <view class="train-zonebar-track">
                <view class="train-zonebar-fill {{item.fillClass}}" style="width: {{item.actualClamped}}%;"></view>
                <view
                  wx:if="{{item.hasTarget}}"
                  class="train-zonebar-target"
                  style="left: {{item.targetClamped}}%;"
                ></view>
              </view>
            </view>
          </block>

          <block wx:if="{{activePill === 'compliance'}}">
            <block wx:if="{{complianceSufficient}}">
              <text wx:if="{{hasComplianceEstimateNote}}" class="train-compliance-note ts-muted">
                {{complianceEstimateNote}}
              </text>
              <view class="train-bar-legend">
                <view class="train-bar-legend-item">
                  <view class="train-bar-legend-dot train-bar-legend-dot--planned"></view>
                  <text class="train-bar-legend-label">{{tr.plannedLabel}}</text>
                </view>
                <view class="train-bar-legend-item">
                  <view class="train-bar-legend-dot train-bar-legend-dot--ok"></view>
                  <text class="train-bar-legend-label">{{tr.complianceOk}}</text>
                </view>
                <view class="train-bar-legend-item">
                  <view class="train-bar-legend-dot train-bar-legend-dot--off"></view>
                  <text class="train-bar-legend-label">{{tr.complianceOff}}</text>
                </view>
                <view class="train-bar-legend-item">
                  <view class="train-bar-legend-dot train-bar-legend-dot--noplan"></view>
                  <text class="train-bar-legend-label">{{tr.complianceNoPlan}}</text>
                </view>
              </view>
              <bar-chart
                canvas-id="train-compliance"
                height="{{280}}"
                weeks="{{complianceWeeks}}"
                planned="{{compliancePlanned}}"
                actual="{{complianceActual}}"
                actual-colors="{{complianceActualColors}}"
                theme="{{chartTheme}}"
              />
            </block>
            <view wx:else class="train-data-hint">
              <text class="train-data-hint-message ts-muted">{{complianceHintMessage}}</text>
              <text class="train-data-hint-detail ts-muted">{{complianceHintDetail}}</text>
            </view>
          </block>
        </view>

        <!-- Praxys Coach receipt — always rendered. AI content when a
             training_review row exists; rule-based prose (diagnosis
             findings + zone deviations + worst-deviation rec) as
             deterministic fallback. The receipt is the single
             narrative-interpretation surface across pages, so it
             persists with or without LLM. -->
        <view class="coach-receipt train-coach" aria-label="{{coachTr.aria}}">
          <view class="coach-banner">
            <text class="coach-mark">{{coachTr.mark}}</text>
            <text wx:if="{{coach.stamp}}" class="coach-stamp ts-value">{{coach.stamp}}</text>
          </view>
          <view class="coach-body">
            <text class="coach-headline">{{coach.headline}}</text>

            <!-- Progressive-disclosure toggle. Default-collapsed; the
                 user opts in to the structured detail. Hidden when
                 the receipt has neither findings nor recommendations
                 (the toggle would be a no-op). -->
            <view
              wx:if="{{coachToggleLabel}}"
              class="coach-toggle"
              hover-class="coach-toggle-press"
              bindtap="onToggleCoachDetails"
              aria-expanded="{{detailsOpen}}"
            >
              <text class="coach-toggle-caret">{{detailsOpen ? '▾' : '▸'}}</text>
              <text>{{coachToggleLabel}}</text>
            </view>

            <block wx:if="{{detailsOpen && coach.hasFindings}}">
              <text class="coach-label">{{coachTr.findings}}</text>
              <view
                wx:for="{{coach.findings}}"
                wx:key="id"
                class="coach-row coach-row--{{item.tone}}"
              >
                <text class="coach-tag">{{item.marker}}</text>
                <text class="coach-text">{{item.text}}</text>
              </view>
            </block>

            <view
              wx:if="{{detailsOpen && coach.hasFindings && coach.hasRecommendations}}"
              class="coach-rule"
            ></view>

            <block wx:if="{{detailsOpen && coach.hasRecommendations}}">
              <text class="coach-label">{{coachTr.recommendations}}</text>
              <view
                wx:for="{{coach.recommendations}}"
                wx:key="index"
                class="coach-row"
              >
                <text class="coach-tag coach-tag--rec">{{item.index}}.</text>
                <text class="coach-text">{{item.text}}</text>
              </view>
            </block>
          </view>
          <insight-feedback
            wx:if="{{coachDatasetHash}}"
            insight-type="training_review"
            dataset-hash="{{coachDatasetHash}}"
            initial-vote="{{coachFeedbackVote}}"
            bindstale="onCoachFeedbackStale"
          />
        </view>
      </block>
    </block>
    </view>
  </scroll-view>
</view>
