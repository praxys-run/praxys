<view class="train-root {{themeClass}}">
  <nav-bar title="{{tr.navTitle}}" theme-class="{{themeClass}}" />

  <scroll-view
    scroll-y="{{true}}"
    refresher-enabled="{{true}}"
    refresher-triggered="{{refreshing}}"
    bindrefresherrefresh="onScrollRefresh"
    scroll-into-view="{{scrollIntoView}}"
    class="train-scroll"
  >
    <view class="train-content">

    <block wx:if="{{loading && !hasResponse}}">
      <state-card type="loading" />
      <state-card type="loading" />
    </block>

    <block wx:elif="{{errorMessage}}">
      <state-card type="error" headline="{{tr.failedToLoad}}" detail="{{errorMessage}}" show-retry bindretry="onRetry" />
    </block>

    <block wx:elif="{{hasResponse}}">
      <state-card wx:if="{{!hasAnyData}}" type="empty" headline="{{tr.noData}}" />

      <!-- ═══════════════════════════════════════════════════════════
           DIAGNOSIS · stat strip + longitudinal heat story + chart
           switcher + Coach receipt. Heat owns its own progressive
           evidence disclosures instead of competing as a chart tab.
           ═══════════════════════════════════════════════════════════ -->
      <block>
        <text wx:if="{{hasAnyData}}" class="train-section-eyebrow">{{tr.diagnosis}} · {{diagnosisEyebrow}}</text>

        <!-- Stat strip — 2x2 grid on phone (stacked rows of two,
             columns aligned). Each cell: mono uppercase label, big
             tabular value with optional % unit, mono caption. Values
             remain neutral because these are descriptive metrics. -->
        <view wx:if="{{hasAnyData}}" class="train-stats">
          <view
            wx:for="{{cells}}"
            wx:key="id"
            class="train-stat-cell"
          >
            <text class="train-stat-label">{{item.label}}</text>
            <view class="train-stat-row">
              <text class="train-stat-value ts-value">{{item.value}}</text>
              <text wx:if="{{item.unit}}" class="train-stat-unit">{{item.unit}}</text>
            </view>
            <text class="train-stat-sub">{{item.sub}}</text>
          </view>
        </view>

        <view id="heat-adaptation" class="train-heat-section" aria-label="{{heat.label}}">
          <view class="train-heat-head">
            <text class="train-heat-label">{{heat.label}}</text>
            <view class="train-heat-stage train-heat-stage--{{heat.tone}}">
              <text>{{heat.stage}}</text>
            </view>
          </view>
          <text class="train-heat-condition ts-value">{{heat.conditionRange}}</text>
          <text class="train-heat-interpretation">{{heat.interpretation}}</text>
          <text wx:if="{{heat.basis}}" class="train-heat-basis ts-value">{{heat.basis}}</text>
          <text wx:if="{{heat.guidance}}" class="train-heat-guidance">{{heat.guidance}}</text>
          <text class="train-heat-safety">{{heat.safetyText}}</text>

          <view
            class="train-heat-disclosure"
            role="button"
            aria-expanded="{{heatEvidenceExpanded}}"
            bindtap="onToggleHeatEvidence"
          >
            <view class="train-heat-disclosure-copy">
              <text>{{heat.evidenceDisclosureLabel}}</text>
              <text class="train-heat-disclosure-meta ts-value">{{heat.evidenceDisclosureMeta}}</text>
            </view>
            <text class="train-heat-disclosure-arrow">{{heatEvidenceExpanded ? '▾' : '▸'}}</text>
          </view>
          <view wx:if="{{heatEvidenceExpanded}}" class="train-heat-evidence">
            <view class="train-heat-evidence-summary">
              <view wx:for="{{heat.evidenceRows}}" wx:key="id" class="train-heat-evidence-row">
                <text class="train-heat-evidence-label">{{item.label}}</text>
                <text class="train-heat-evidence-value ts-value">{{item.value}}</text>
              </view>
            </view>

            <view wx:if="{{heat.showCadence}}" class="train-heat-cadence">
              <text class="train-heat-cadence-label">{{heat.cadenceLabel}}</text>
              <text class="train-heat-cadence-description">{{heat.cadenceDescription}}</text>
              <view class="train-heat-cadence-legend">
                <view class="train-heat-cadence-legend-item">
                  <view class="train-heat-cadence-mark train-heat-cadence-mark--included"></view>
                  <text>{{heat.includedLegend}}</text>
                </view>
                <view class="train-heat-cadence-legend-item">
                  <view class="train-heat-cadence-mark train-heat-cadence-mark--observed"></view>
                  <text>{{heat.observedLegend}}</text>
                </view>
              </view>
              <view class="train-heat-cadence-grid">
                <view wx:for="{{heat.cadenceDays}}" wx:key="id" class="train-heat-day-wrap">
                  <view
                    class="train-heat-day {{selectedHeatDayId === item.id ? 'train-heat-day--selected' : ''}}"
                    data-id="{{item.id}}"
                    bindtap="onPickHeatDay"
                    role="button"
                    aria-label="{{item.detail}}"
                    aria-pressed="{{selectedHeatDayId === item.id}}"
                  >
                    <text class="train-heat-day-weekday">{{item.weekday}}</text>
                    <view class="train-heat-day-marker train-heat-day-marker--{{item.state}}"></view>
                    <text class="train-heat-day-number ts-value">{{item.dayNumber}}</text>
                  </view>
                </view>
              </view>
              <text class="train-heat-cadence-detail ts-value" aria-live="polite">{{selectedHeatDayDetail}}</text>
            </view>

            <view class="train-heat-sessions">
              <text class="train-heat-sessions-label">{{heat.sessionsLabel}}</text>
              <text class="train-heat-sessions-description">{{heat.sessionsDescription}}</text>
            </view>
            <view wx:if="{{heat.hasSessions}}">
              <view
                wx:for="{{heat.sessions}}"
                wx:key="id"
                class="train-heat-row"
              >
                <view
                  class="train-heat-row-toggle"
                  data-id="{{item.id}}"
                  bindtap="onToggleHeatSession"
                  role="button"
                  aria-expanded="{{expandedHeatSessionId === item.id}}"
                >
                  <view class="train-heat-row-main">
                    <view class="train-heat-row-head">
                      <text class="train-heat-date ts-value">{{item.date}}</text>
                      <text class="train-heat-row-status train-heat-row-status--{{item.tone}}">{{item.status}}</text>
                    </view>
                    <text class="train-heat-environment ts-value">{{item.environment}}</text>
                    <text class="train-heat-effective ts-value">{{item.effective}}</text>
                  </view>
                  <text class="train-heat-disclosure-arrow">{{expandedHeatSessionId === item.id ? '▾' : '▸'}}</text>
                </view>
                <view wx:if="{{expandedHeatSessionId === item.id}}" class="train-heat-row-detail">
                  <text class="train-heat-row-reason">{{item.reason}}</text>
                  <text>{{item.weatherEvidence}}</text>
                  <text>{{item.workloadMethod}}</text>
                  <text>{{item.powerAlignment}}</text>
                </view>
              </view>
            </view>
            <view wx:else class="train-data-hint">
              <text class="train-data-hint-message ts-muted">{{heat.emptySessionsText}}</text>
            </view>
            <view
              class="train-heat-science-link"
              role="button"
              bindtap="onOpenHeatScience"
            >
              <view class="train-heat-science-copy">
                <text class="train-heat-science-note">{{heat.scienceNote}}</text>
                <text class="train-heat-science-action">{{heat.scienceLinkLabel}}</text>
              </view>
              <text class="train-heat-science-arrow" aria-hidden="true">→</text>
            </view>
          </view>
        </view>

        <!-- Pill switcher. Persists active to wx storage so power
             users land on their preferred chart on every visit.
             Zones pill is conditional on at least one zone having
             a target — without it the pill renders inert and
             invites a bug. -->
        <view wx:if="{{hasAnyData}}" class="train-pills" role="tablist" aria-label="{{tr.diagnosis}}">
          <view
            class="train-pill {{activePill === 'form' ? 'train-pill--active' : ''}}"
            data-pill="form"
            bindtap="onPickPill"
            role="tab"
            aria-selected="{{activePill === 'form'}}"
          >{{tr.pillForm}}</view>
          <view
            wx:if="{{hasZones}}"
            class="train-pill {{activePill === 'zones' ? 'train-pill--active' : ''}}"
            data-pill="zones"
            bindtap="onPickPill"
            role="tab"
            aria-selected="{{activePill === 'zones'}}"
          >{{tr.pillZones}}</view>
          <view
            class="train-pill {{activePill === 'compliance' ? 'train-pill--active' : ''}}"
            data-pill="compliance"
            bindtap="onPickPill"
            role="tab"
            aria-selected="{{activePill === 'compliance'}}"
          >{{tr.pillCompliance}}</view>
        </view>

        <!-- Active chart pane. One option visible at a time; the
             switcher above flips between them. Each option carries
             its own DataHint countdown copy when the underlying
             window isn't long enough yet. -->
        <view wx:if="{{hasAnyData}}" class="train-chart-pane">
          <block wx:if="{{activePill === 'form'}}">
            <line-chart
              wx:if="{{ffSufficient}}"
              canvas-id="train-ctl-atl-tsb"
              height="{{280}}"
              show-zero-line="{{true}}"
              dates="{{ffDates}}"
              series="{{ffSeries}}"
              theme="{{chartTheme}}"
            />
            <view wx:else class="train-data-hint">
              <text class="train-data-hint-message ts-muted">{{ffHintMessage}}</text>
              <text class="train-data-hint-detail ts-muted">{{ffHintDetail}}</text>
            </view>
          </block>

          <block wx:if="{{activePill === 'zones' && hasZones}}">
            <text class="train-zone-section-label">{{zoneSectionLabel}}</text>
            <view
              wx:for="{{zoneRows}}"
              wx:key="name"
              class="train-zonebar"
            >
              <view class="train-zonebar-head">
                <text class="train-zonebar-name">{{item.name}}</text>
                <text class="train-zonebar-value ts-value">{{item.label}}</text>
              </view>
              <view class="train-zonebar-track">
                <view class="train-zonebar-fill" style="width: {{item.actualClamped}}%;"></view>
                <view
                  wx:if="{{item.hasTarget}}"
                  class="train-zonebar-target"
                  style="left: {{item.targetClamped}}%;"
                ></view>
              </view>
            </view>
            <text class="train-methodology ts-muted">{{tr.zoneMethodology}}</text>
          </block>

          <block wx:if="{{activePill === 'compliance'}}">
            <block wx:if="{{complianceSufficient}}">
              <text wx:if="{{hasComplianceEstimateNote}}" class="train-compliance-note ts-muted">
                {{complianceEstimateNote}}
              </text>
              <view class="train-bar-legend">
                <view class="train-bar-legend-item">
                  <view class="train-bar-legend-dot train-bar-legend-dot--planned"></view>
                  <text class="train-bar-legend-label">{{tr.plannedLabel}}</text>
                </view>
                <view class="train-bar-legend-item">
                  <view class="train-bar-legend-dot train-bar-legend-dot--actual"></view>
                  <text class="train-bar-legend-label">{{tr.actualLabel}}</text>
                </view>
              </view>
              <bar-chart
                canvas-id="train-compliance"
                height="{{280}}"
                weeks="{{complianceWeeks}}"
                planned="{{compliancePlanned}}"
                actual="{{complianceActual}}"
                estimated="{{complianceEstimated}}"
                theme="{{chartTheme}}"
              />
              <text class="train-methodology ts-muted">{{tr.complianceMethodology}}</text>
            </block>
            <view wx:else class="train-data-hint">
              <text class="train-data-hint-message ts-muted">{{complianceHintMessage}}</text>
              <text class="train-data-hint-detail ts-muted">{{complianceHintDetail}}</text>
            </view>
          </block>

        </view>

        <!-- Praxys Coach receipt — always rendered. AI content when a
             training_review row exists; rule-based prose (diagnosis
             findings + zone deviations + worst-deviation rec) as
             deterministic fallback. The receipt is the single
             narrative-interpretation surface across pages, so it
             persists with or without LLM. -->
        <view wx:if="{{hasAnyData}}" class="coach-receipt train-coach" aria-label="{{coachTr.aria}}">
          <view class="coach-banner">
            <text class="coach-mark">{{coachTr.mark}}</text>
            <text wx:if="{{coach.stamp}}" class="coach-stamp ts-value">{{coach.stamp}}</text>
          </view>
          <view class="coach-body">
            <text class="coach-headline">{{coach.headline}}</text>

            <!-- Progressive-disclosure toggle. Default-collapsed; the
                 user opts in to the structured detail. Hidden when
                 the receipt has neither findings nor recommendations
                 (the toggle would be a no-op). -->
            <view
              wx:if="{{coachToggleLabel}}"
              class="coach-toggle"
              hover-class="coach-toggle-press"
              bindtap="onToggleCoachDetails"
              aria-expanded="{{detailsOpen}}"
            >
              <text class="coach-toggle-caret">{{detailsOpen ? '▾' : '▸'}}</text>
              <text>{{coachToggleLabel}}</text>
            </view>

            <block wx:if="{{detailsOpen && coach.hasFindings}}">
              <text class="coach-label">{{coachTr.findings}}</text>
              <view
                wx:for="{{coach.findings}}"
                wx:key="id"
                class="coach-row coach-row--{{item.tone}}"
              >
                <text class="coach-tag">{{item.marker}}</text>
                <text class="coach-text">{{item.text}}</text>
              </view>
            </block>

            <view
              wx:if="{{detailsOpen && coach.hasFindings && coach.hasRecommendations}}"
              class="coach-rule"
            ></view>

            <block wx:if="{{detailsOpen && coach.hasRecommendations}}">
              <text class="coach-label">{{coachTr.recommendations}}</text>
              <view
                wx:for="{{coach.recommendations}}"
                wx:key="index"
                class="coach-row"
              >
                <text class="coach-tag coach-tag--rec">{{item.index}}.</text>
                <text class="coach-text">{{item.text}}</text>
              </view>
            </block>
          </view>
          <insight-feedback
            wx:if="{{coachDatasetHash}}"
            insight-type="training_review"
            dataset-hash="{{coachDatasetHash}}"
            initial-vote="{{coachFeedbackVote}}"
            bindstale="onCoachFeedbackStale"
          />
        </view>
      </block>
    </block>
    </view>
  </scroll-view>
</view>
