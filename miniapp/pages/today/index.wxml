<view class="today-root {{themeClass}}">
  <nav-bar title="{{tr.navTitle}}" theme-class="{{themeClass}}" show-wordmark="{{true}}" />

  <scroll-view
    scroll-y="{{true}}"
    refresher-enabled="{{true}}"
    refresher-triggered="{{refreshing}}"
    bindrefresherrefresh="onScrollRefresh"
    class="today-scroll"
  >
    <view class="today-content">
      <text class="today-date">{{today}}</text>

    <block wx:if="{{loading && !hasResponse}}">
      <state-card type="loading" />
      <state-card type="loading" />
    </block>

    <block wx:elif="{{errorMessage}}">
      <state-card type="error" headline="{{tr.failedToLoad}}" detail="{{errorMessage}}" show-retry bindretry="onRetry" />
    </block>

    <block wx:elif="{{!hasResponse}}">
      <state-card type="empty" headline="{{tr.noDataYet}}" />
    </block>

    <block wx:else>
      <!--
        Page-level data-staleness banner — fires when `data_as_of`'s
        local-TZ calendar date is older than today. Anchors on the
        actual data timestamp, not the sync attempt. The action pair
        (Sync now / Show anyway) is the user's escape hatch.
        Suppressed once dismissed — the chip below takes over.
      -->
      <view
        wx:if="{{dataStale && !staleDismissed}}"
        class="today-data-stale-banner"
      >
        <view class="today-data-stale-text">
          <text class="today-data-stale-headline">{{staleHeadline}}</text>
          <text class="today-data-stale-detail ts-value">{{staleDetail}}</text>
        </view>
        <view class="today-data-stale-actions">
          <view
            class="today-data-stale-btn today-data-stale-btn--primary {{staleSyncing ? 'today-data-stale-btn--disabled' : ''}}"
            bindtap="onStaleSyncNow"
            hover-class="today-data-stale-btn--press"
          >
            <text>{{staleSyncing ? staleSyncingLabel : staleSyncLabel}}</text>
          </view>
          <view
            class="today-data-stale-btn today-data-stale-btn--ghost"
            bindtap="onStaleShowAnyway"
            hover-class="today-data-stale-btn--press"
          >
            <text>{{staleShowAnywayLabel}}</text>
          </view>
        </view>
      </view>
      <!--
        Compact chip variant — shown after Show anyway. Same anchor as
        the banner (data_as_of timestamp) so the page never lies about
        the data's age, even when the user has chosen to view it.
      -->
      <view
        wx:if="{{dataStale && staleDismissed}}"
        class="today-data-stale-chip"
      >
        <view class="today-data-stale-chip-dot"></view>
        <text class="today-data-stale-chip-text">{{staleChipText}}</text>
        <view
          class="today-data-stale-chip-link {{staleSyncing ? 'today-data-stale-btn--disabled' : ''}}"
          bindtap="onStaleSyncNow"
          hover-class="today-data-stale-btn--press"
        >
          <text>{{staleSyncing ? staleSyncingLabel : staleSyncLabel}}</text>
        </view>
      </view>
      <!--
        Recovery-only staleness advisory (PR #254 surface). Suppressed
        when the page-level banner is up — the page-level signal is
        strictly more general, so showing both would just be noise.
      -->
      <view wx:if="{{stalenessText}}" class="today-staleness-banner">
        <text class="today-staleness-text">{{stalenessText}}</text>
      </view>
      <view class="ts-card signal-hero {{dataStale && !staleDismissed ? 'is-sync-stale' : ''}}">
        <view
          class="signal-share-fab"
          bindtap="onShareCardToggle"
          hover-class="signal-share-fab--press"
        >
          <view class="signal-share-fab__icon"></view>
        </view>
        <view class="signal-circle signal-circle--{{signalColor}}">
          <view class="signal-glow signal-glow--{{signalColor}}"></view>
          <text class="signal-label signal-label--{{signalColor}}">{{signalLabel}}</text>
        </view>
        <text class="signal-subtitle signal-subtitle--{{signalColor}}">{{signalSubtitle}}</text>
        <text wx:if="{{signalReason}}" class="signal-reason">{{signalReason}}</text>
        <view wx:if="{{signalAlternatives.length > 0}}" class="signal-alternatives">
          <view wx:for="{{signalAlternatives}}" wx:key="index" class="coach-row">
            <text class="coach-tag coach-tag--rec">{{item.index}}</text>
            <text class="coach-text">{{item.text}}</text>
          </view>
        </view>
      </view>

      <!--
        Deterministic Praxys Coach receipt. It uses the same canonical
        signal as the verdict, with progressive disclosure for alternatives.
      -->
      <view wx:if="{{hasCoach}}" class="coach-receipt {{dataStale && !staleDismissed ? 'is-sync-stale' : ''}}" aria-label="{{coachTr.aria}}">
        <view class="coach-banner">
          <text class="coach-mark">{{coachTr.mark}}</text>
          <text wx:if="{{coach.stamp}}" class="coach-stamp ts-value">{{coach.stamp}}</text>
        </view>
        <view class="coach-body">
          <text class="coach-headline">{{coach.headline}}</text>

          <!-- Progressive-disclosure toggle. Default-collapsed; the
               user opts in to the structured detail. Hidden when
               the receipt has neither findings nor recommendations
               (the toggle would be a no-op). -->
          <view
            wx:if="{{coachToggleLabel}}"
            class="coach-toggle"
            hover-class="coach-toggle-press"
            bindtap="onToggleCoachDetails"
            aria-expanded="{{detailsOpen}}"
          >
            <text class="coach-toggle-caret">{{detailsOpen ? '▾' : '▸'}}</text>
            <text>{{coachToggleLabel}}</text>
          </view>

          <block wx:if="{{detailsOpen && coach.hasFindings}}">
            <text class="coach-label">{{coachTr.findings}}</text>
            <view
              wx:for="{{coach.findings}}"
              wx:key="id"
              class="coach-row coach-row--{{item.tone}}"
            >
              <text class="coach-tag">{{item.marker}}</text>
              <text class="coach-text">{{item.text}}</text>
            </view>
          </block>

          <view
            wx:if="{{detailsOpen && coach.hasFindings && coach.hasRecommendations}}"
            class="coach-rule"
          ></view>

          <block wx:if="{{detailsOpen && coach.hasRecommendations}}">
            <text class="coach-label">{{coachTr.recommendations}}</text>
            <view
              wx:for="{{coach.recommendations}}"
              wx:key="index"
              class="coach-row"
            >
              <text class="coach-tag coach-tag--rec">{{item.index}}.</text>
              <text class="coach-text">{{item.text}}</text>
            </view>
          </block>
        </view>

        <view wx:if="{{coach.attribution}}" class="coach-foot">
          <text class="coach-foot-text">{{coach.attribution}}</text>
        </view>
      </view>

      <!--
        Supporting cells: a flat 2-col grid mirroring web's PR #238
        layout. Five cells in source order — HRV, observation trend, RHR, Sleep,
        TSB. Cardless on warm paper with hairline separators between
        cells; the last cell (TSB, index 4) spans both columns to avoid
        a stranded empty slot. Pure data-driven; the cells array is
        always present once `hasResponse` is true, so no `wx:if` guard
        wraps the block.
      -->
      <view class="today-supporting {{dataStale && !staleDismissed ? 'is-sync-stale' : ''}}">
        <view
          wx:for="{{cells}}"
          wx:key="id"
          class="today-cell {{item.span ? 'today-cell--span' : ''}}"
        >
          <text class="today-cell-label">{{item.label}}</text>
          <text class="today-cell-value ts-value {{item.valueAccent}}">{{item.value}}</text>
          <text class="today-cell-sub ts-value">{{item.sub}}</text>
        </view>
      </view>

      <view class="today-heat" aria-label="{{heat.label}}">
        <view class="today-heat-head">
          <text class="today-heat-label">{{heat.label}}</text>
          <view class="today-heat-stage today-heat-stage--{{heat.tone}}">
            <view class="today-heat-dot"></view>
            <text>{{heat.stage}}</text>
          </view>
        </view>
        <text class="today-heat-action">{{heat.action}}</text>
        <view class="today-heat-meta">
          <text class="ts-value">{{heat.evidence}}</text>
          <text class="ts-value">{{heat.lastExposure}}</text>
          <text>{{heat.confidence}}</text>
        </view>
        <view class="today-heat-methodology">
          <view
            class="today-heat-methodology-toggle"
            role="button"
            aria-expanded="{{heatMethodologyExpanded}}"
            bindtap="toggleHeatMethodology"
          >
            <text class="today-heat-methodology-arrow">{{heatMethodologyExpanded ? '▾' : '▸'}}</text>
            <text class="today-heat-methodology-label">{{heat.methodologyLabel}}</text>
          </view>
          <view wx:if="{{heatMethodologyExpanded}}" class="today-heat-methodology-body">
            <text class="today-heat-methodology-text">{{heat.methodologyText}}</text>
            <view
              wx:for="{{heat.sources}}"
              wx:key="id"
              class="today-heat-source-row"
              data-url="{{item.url}}"
              bindtap="onTapMethodologySource"
            >
              <text class="today-heat-source">{{item.label}}</text>
              <text class="today-heat-source-action">{{heat.sourceActionLabel}}</text>
            </view>
          </view>
        </view>
      </view>

      <!--
        Plan one-liner: the day's planned workout, eyebrow + body in a
        single baseline-aligned row. Replaces the prior Upcoming
        Workouts list and full WorkoutCard.
      -->
      <view class="today-plan">
        <text class="today-plan-eyebrow">{{planEyebrow}}</text>
        <text class="today-plan-text">{{planText}}</text>
      </view>

      <view class="today-methodology">
        <view class="today-methodology-toggle" bindtap="toggleMethodology">
          <text class="today-methodology-arrow">{{methodologyExpanded ? '▾' : '▸'}}</text>
          <text class="today-methodology-label">{{methodologyLabel}}</text>
        </view>
        <view wx:if="{{methodologyExpanded}}" class="today-methodology-body">
          <text class="today-methodology-text">{{methodologyText}}</text>
          <view
            wx:for="{{methodologySources}}"
            wx:key="id"
            class="today-methodology-source-row"
            data-url="{{item.url}}"
            bindtap="onTapMethodologySource"
          >
            <text class="today-methodology-source">{{item.label}}</text>
            <text class="today-methodology-source-action">{{methodologySourceActionLabel}}</text>
          </view>
        </view>
      </view>

      <view wx:if="{{hasWarnings}}" class="today-warnings">
        <text class="ts-section-label">{{tr.warnings}}</text>
        <text
          wx:for="{{warnings}}"
          wx:key="*this"
          class="today-warning-item ts-warning"
        >• {{item}}</text>
      </view>
      <decision-check eligible="{{decisionCheckEligible}}" />

    </block>
    </view>
  </scroll-view>

  <!-- Share card overlay — appears above everything when FAB is tapped.
       User long-presses the image to get WeChat's native "Save image"
       context menu, then shares from camera roll. Tap the backdrop to
       dismiss. show-menu-by-longpress on the <image> surfaces the native
       save/forward sheet; no extra hint text is needed. -->
  <view wx:if="{{shareCardVisible}}" class="share-overlay" bindtap="onShareCardToggle">
    <view class="share-overlay-sheet" catchtap="noop">
      <view wx:if="{{!shareImagePath}}" class="share-overlay-loading">
        <view class="ts-skeleton share-overlay-skeleton"></view>
      </view>
      <image
        wx:if="{{shareImagePath}}"
        class="share-overlay-image"
        src="{{shareImagePath}}"
        mode="widthFix"
        show-menu-by-longpress="{{true}}"
      />
      <text class="share-overlay-close ts-muted" bindtap="onShareCardToggle">{{tr.close}}</text>
    </view>
  </view>
</view>
