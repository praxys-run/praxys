<view class="goal-root {{themeClass}}">
  <nav-bar title="{{tr.navTitle}}" theme-class="{{themeClass}}" />

  <scroll-view
    scroll-y="{{true}}"
    refresher-enabled="{{true}}"
    refresher-triggered="{{refreshing}}"
    bindrefresherrefresh="onScrollRefresh"
    class="goal-scroll"
  >
    <view class="goal-content">

      <block wx:if="{{loading && !hasResponse}}">
        <state-card type="loading" />
      </block>

      <block wx:elif="{{errorMessage}}">
        <state-card type="error" headline="{{tr.failedToLoad}}" detail="{{errorMessage}}" show-retry bindretry="onRetry" />
      </block>

      <block wx:elif="{{hasResponse}}">

        <!-- Trajectory header — shared by all modes.
             Eyebrow: mode context (Race/Goal/Tracking) + optional status badge.
             Headline: one-sentence verdict with key numbers. -->
        <view class="goal-eyebrow-row">
          <text class="goal-eyebrow">{{goalEyebrow}}</text>
          <text wx:if="{{showStatusBadge}}" class="goal-status-badge {{statusAccent}}">{{statusText}}</text>
        </view>
        <text class="goal-headline">{{goalHeadline}}</text>

        <!-- CP trend chart — shown when enough data exists.
             Reference line marks target CP for race_date / cp_milestone;
             null on continuous mode (no target). -->
        <view wx:if="{{hasCpTrend}}" class="ts-card">
          <text class="ts-section-label">{{tr.cpTrend}}</text>
          <line-chart
            canvas-id="goal-cp-trend"
            height="{{240}}"
            show-legend="{{false}}"
            dates="{{cpTrendDates}}"
            series="{{cpTrendSeries}}"
            reference-y="{{cpTrendReferenceY}}"
            y-unit="{{cpTrendUnit}}"
            theme="{{chartTheme}}"
          />
        </view>

        <!-- Praxys Coach receipt — conditional on race_forecast insight.
             Nil-renders when LLM is disabled or no insight exists. -->
        <view wx:if="{{hasCoach}}" class="coach-receipt">
          <view class="coach-banner">
            <text class="coach-mark">{{coachTr.mark}}</text>
            <text wx:if="{{coach.stamp}}" class="coach-stamp ts-value">{{coach.stamp}}</text>
          </view>
          <view class="coach-body">
            <text class="coach-headline">{{coach.headline}}</text>
            <insight-feedback
              wx:if="{{coachDatasetHash}}"
              insight-type="race_forecast"
              dataset-hash="{{coachDatasetHash}}"
              initial-vote="{{coachFeedbackVote}}"
              bindstale="onCoachFeedbackStale"
            />

            <!-- Progressive-disclosure toggle. Default-collapsed; the
                 user opts in to the structured detail. Hidden when
                 the receipt has neither findings nor recommendations
                 (the toggle would be a no-op). -->
            <view
              wx:if="{{coachToggleLabel}}"
              class="coach-toggle"
              hover-class="coach-toggle-press"
              bindtap="onToggleCoachDetails"
              aria-expanded="{{detailsOpen}}"
            >
              <text class="coach-toggle-caret">{{detailsOpen ? '▾' : '▸'}}</text>
              <text>{{coachToggleLabel}}</text>
            </view>

            <block wx:if="{{detailsOpen && coach.hasFindings}}">
              <text class="coach-label">{{coachTr.findings}}</text>
              <view
                wx:for="{{coach.findings}}"
                wx:key="id"
                class="coach-row coach-row--{{item.tone}}"
              >
                <text class="coach-tag">{{item.marker}}</text>
                <text class="coach-text">{{item.text}}</text>
              </view>
            </block>

            <view
              wx:if="{{detailsOpen && coach.hasFindings && coach.hasRecommendations}}"
              class="coach-rule"
            ></view>

            <block wx:if="{{detailsOpen && coach.hasRecommendations}}">
              <text class="coach-label">{{coachTr.recommendations}}</text>
              <view
                wx:for="{{coach.recommendations}}"
                wx:key="index"
                class="coach-row"
              >
                <text class="coach-tag coach-tag--rec">{{item.index}}.</text>
                <text class="coach-text">{{item.text}}</text>
              </view>
            </block>
          </view>
        </view>

        <!-- Stats strip — mode-specific cells with key metrics. -->
        <view wx:if="{{stripCells.length > 0}}" class="goal-strip">
          <view
            wx:for="{{stripCells}}"
            wx:key="id"
            class="goal-strip-cell"
          >
            <text class="goal-strip-label">{{item.label}}</text>
            <text class="goal-strip-value ts-value {{item.accent}}">{{item.value}}</text>
            <text wx:if="{{item.sub}}" class="goal-strip-sub">{{item.sub}}</text>
          </view>
        </view>

        <!-- Realistic alternative targets — race_date mode only,
             shown when severity is behind or unlikely. -->
        <view wx:if="{{showRealisticTargets}}" class="goal-section">
          <text class="goal-section-label">{{tr.realisticTargets}}</text>
          <view class="goal-alts-grid">
            <view class="goal-alts-cell">
              <text class="goal-strip-label">{{tr.comfortable}}</text>
              <text class="goal-strip-value ts-value goal-strip-positive">{{rdComfortable}}</text>
            </view>
            <view class="goal-alts-cell">
              <text class="goal-strip-label">{{tr.stretch}}</text>
              <text class="goal-strip-value ts-value goal-strip-amber">{{rdStretch}}</text>
            </view>
          </view>
        </view>

        <!-- Trend rationale — rule-based prose, suppressed when coach receipt is shown. -->
        <text wx:if="{{hasRationale}}" class="goal-rationale">{{rationaleText}}</text>

        <!-- Science notes — expandable "How this is calculated" sections.
             Tap-to-copy source links because WeChat rich-text <a> doesn't navigate. -->
        <view
          wx:if="{{notePredictionText}}"
          class="ts-card goal-note-card"
        >
          <view class="goal-note-toggle" bindtap="toggleNotePrediction">
            <text class="goal-note-arrow">{{notePredictionExpanded ? '▾' : '▸'}}</text>
            <text class="goal-note-label">{{tr.howCalculated}}</text>
          </view>
          <view wx:if="{{notePredictionExpanded}}" class="goal-note-body">
            <text class="goal-note-text">{{notePredictionText}}</text>
            <view
              wx:if="{{notePredictionUrl}}"
              class="goal-note-source-row"
              bindtap="onTapPredictionSource"
            >
              <text class="goal-note-source">{{tr.sourceTapCopy}}</text>
            </view>
          </view>
        </view>

        <view
          wx:if="{{hasUltraNote}}"
          class="ts-card goal-note-card"
        >
          <view class="goal-note-toggle" bindtap="toggleNoteUltra">
            <text class="goal-note-arrow">{{noteUltraExpanded ? '▾' : '▸'}}</text>
            <text class="goal-note-label">{{tr.ultraCaveat}}</text>
          </view>
          <view wx:if="{{noteUltraExpanded}}" class="goal-note-body">
            <text class="goal-note-text">{{noteUltraText}}</text>
            <view class="goal-note-source-row" bindtap="onTapUltraSource">
              <text class="goal-note-source">{{tr.discussionTapCopy}}</text>
            </view>
          </view>
        </view>

      </block>

    </view>
  </scroll-view>

  <!-- Goal editor bottom sheet — unchanged from previous version.
       No bindtap on the mask — avoids Skyline touch absorption issues.
       Cancel/Save in the header are the only dismiss paths. -->
  <view wx:if="{{editorOpen}}" class="goal-editor-mask">
    <view class="goal-editor-sheet">
      <view wx:if="{{!editorConfirmDiscard}}" class="goal-editor-header">
        <view
          class="goal-editor-header-action goal-editor-header-action--cancel {{editorSaving ? 'goal-editor-header-action--disabled' : ''}}"
          bindtap="onCloseEditor"
        >
          <text>{{tr.cancel}}</text>
        </view>
        <text class="goal-editor-title">{{tr.editorTitle}}</text>
        <view
          class="goal-editor-header-action goal-editor-header-action--save {{(!editorDirty || editorSaving) ? 'goal-editor-header-action--disabled' : ''}}"
          bindtap="onSaveEditor"
        >
          <text>{{editorSaving ? tr.saving : tr.save}}</text>
        </view>
      </view>
      <view wx:else class="goal-editor-header goal-editor-header--confirm">
        <text class="goal-editor-confirm-prompt ts-muted">{{tr.discardPrompt}}</text>
        <view class="goal-editor-header-action goal-editor-header-action--cancel" bindtap="onDiscardKeep">
          <text>{{tr.keepEditing}}</text>
        </view>
        <view class="goal-editor-header-action goal-editor-header-action--discard" bindtap="onDiscardConfirm">
          <text>{{tr.discardConfirm}}</text>
        </view>
      </view>

      <text class="goal-editor-label ts-muted">{{tr.goalType}}</text>
      <view class="goal-editor-toggle">
        <view
          class="goal-editor-toggle-item {{editorType === 'race' ? 'goal-editor-toggle-item--active' : ''}}"
          data-type="race"
          bindtap="onPickEditorType"
        >
          <text class="goal-editor-toggle-label">{{tr.raceGoal}}</text>
          <text class="goal-editor-toggle-desc ts-muted">{{tr.raceGoalDesc}}</text>
        </view>
        <view
          class="goal-editor-toggle-item {{editorType === 'continuous' ? 'goal-editor-toggle-item--active' : ''}}"
          data-type="continuous"
          bindtap="onPickEditorType"
        >
          <text class="goal-editor-toggle-label">{{tr.continuousGoal}}</text>
          <text class="goal-editor-toggle-desc ts-muted">{{tr.continuousGoalDesc}}</text>
        </view>
      </view>

      <text class="goal-editor-label ts-muted">{{tr.distance}}</text>
      <picker
        mode="selector"
        range="{{editorDistanceLabels}}"
        value="{{editorDistanceIndex}}"
        bindchange="onPickEditorDistance"
      >
        <view class="goal-editor-input">
          <text class="goal-editor-input-value">{{editorDistanceLabels[editorDistanceIndex]}}</text>
          <text class="goal-editor-input-chev ts-muted">›</text>
        </view>
      </picker>

      <block wx:if="{{editorType === 'race'}}">
        <text class="goal-editor-label ts-muted">{{tr.raceDate}}</text>
        <picker
          mode="date"
          value="{{editorRaceDate}}"
          start="{{editorTodayIso}}"
          bindchange="onPickEditorRaceDate"
        >
          <view class="goal-editor-input">
            <text class="goal-editor-input-value">{{editorRaceDate || tr.pickDate}}</text>
            <text class="goal-editor-input-chev ts-muted">›</text>
          </view>
        </picker>
      </block>

      <text class="goal-editor-label ts-muted">{{tr.targetTime}} <text class="ts-muted">({{tr.optional}})</text></text>
      <picker
        mode="multiSelector"
        range="{{editorTimeRange}}"
        value="{{editorTimeParts}}"
        bindchange="onPickEditorTargetTime"
      >
        <view class="goal-editor-input">
          <text class="goal-editor-input-value {{editorTargetDisplay === '—' ? 'ts-muted' : ''}}">{{editorTargetDisplay}}</text>
          <text class="goal-editor-input-chev ts-muted">›</text>
        </view>
      </picker>
      <text class="goal-editor-hint ts-muted">{{tr.targetTimeHint}}</text>

      <text wx:if="{{editorError}}" class="goal-editor-error ts-destructive">{{editorError}}</text>
    </view>
  </view>
</view>
