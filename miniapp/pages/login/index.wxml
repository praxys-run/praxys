<view class="login-root {{themeClass}}">
  <!-- Top-LEFT language toggle. WeChat reserves the top-right for its
       capsule (`...` + `⊙`); placing anything there overlaps it on
       real devices. Tap to switch — writes praxys-language to wx
       storage and reLaunches so all `t()` calls re-resolve. -->
  <view class="login-lang-toggle">
    <text
      class="login-lang-toggle-opt {{locale === 'en' ? 'login-lang-toggle-opt--active' : ''}}"
      data-lang="en"
      bindtap="onSwitchLang"
    >EN</text>
    <text
      class="login-lang-toggle-opt {{locale === 'zh' ? 'login-lang-toggle-opt--active' : ''}}"
      data-lang="zh"
      bindtap="onSwitchLang"
    >中</text>
  </view>

  <!-- Theme toggle: top-LEFT just under the language pill. Three states
       (auto / light / dark) cycle on tap; the active glyph is filled,
       inactive sit muted. SVG masks (sun / moon / monitor) replace the
       unicode glyphs we used to render — Skyline strokes them cleanly,
       and they match the brand's "no emoji icons" rule. -->
  <view class="login-theme-toggle">
    <view
      class="login-theme-opt {{themePref === 'light' ? 'login-theme-opt--active' : ''}}"
      data-theme="light"
      bindtap="onSwitchTheme"
      aria-label="{{tr.themeLight}}"
    >
      <view class="login-theme-icon login-theme-icon--sun"></view>
    </view>
    <view
      class="login-theme-opt {{themePref === 'dark' ? 'login-theme-opt--active' : ''}}"
      data-theme="dark"
      bindtap="onSwitchTheme"
      aria-label="{{tr.themeDark}}"
    >
      <view class="login-theme-icon login-theme-icon--moon"></view>
    </view>
    <view
      class="login-theme-opt {{themePref === 'auto' ? 'login-theme-opt--active' : ''}}"
      data-theme="auto"
      bindtap="onSwitchTheme"
      aria-label="{{tr.themeAuto}}"
    >
      <view class="login-theme-icon login-theme-icon--monitor"></view>
    </view>
  </view>

  <block wx:if="{{stage === 'idle'}}">
    <view class="login-stack">
      <!-- PRIVATE ALPHA · INVITATION ONLY eyebrow — surfaces the alpha
           state on first touch. Cobalt = reasoning surface; the eyebrow
           tells the user "this is a deliberate, scoped product, not a
           closed-down site". Mirrors web's login-hero-eyebrow. -->
      <view class="login-eyebrow fade-in" style="animation-delay: 0ms">
        <view class="login-eyebrow-dot"></view>
        <text class="login-eyebrow-text">{{tr.alphaEyebrow}}</text>
      </view>

      <image class="login-mark fade-in" src="/assets/brand/mark.png" mode="aspectFit"
             style="animation-delay: 60ms" />
      <view class="login-wordmark fade-in" style="animation-delay: 120ms">
        <text class="login-wordmark__text">Pra<text class="login-wordmark__accent">x</text>ys</text>
      </view>

      <!-- Canonical brand-guide tagline. Split into prefix + green-accent
           span + suffix because Skyline's text composition can't put a
           coloured span inside a single text node — we render each
           segment as its own <text>, inline-styled, and let the line wrap
           naturally. en: "Sports science that <accent>meets you</accent>
           where you are." / zh: "运动科学，<accent>知行合一</accent>。" -->
      <view class="login-tagline fade-in" style="animation-delay: 200ms">
        <text class="login-tagline-seg">{{tr.taglinePrefix}}</text>
        <text class="login-tagline-seg login-tagline-accent">{{tr.taglineAccent}}</text>
        <text class="login-tagline-seg">{{tr.taglineSuffix}}</text>
      </view>

      <button class="ts-button login-cta fade-in" style="animation-delay: 280ms"
              bindtap="onSignInTap">{{tr.signInWeChat}}</button>

      <!-- Consent notice for the WeChat sign-in. The primary sign-in carries a
           prominent agreement line with tappable links to the full Terms +
           Privacy docs (pages/legal). WeChat audit requires the agreements be
           reachable and consented before we collect any personal info (email
           on the waitlist / link stages, which additionally gate on a
           checkbox). -->
      <view class="login-consent fade-in" style="animation-delay: 320ms">
        <text class="login-consent-lead">{{tr.consentLead}}</text>
        <view class="login-consent-links">
          <text class="login-consent-link" data-kind="terms" bindtap="onOpenLegal">{{tr.termsName}}</text>
          <text class="login-consent-dot">·</text>
          <text class="login-consent-link" data-kind="privacy" bindtap="onOpenLegal">{{tr.privacyName}}</text>
        </view>
      </view>

      <!-- Three structural pillars. Match web's login-pillars list:
           "Today's signal · go, modify, or rest" / "Diagnosis & forecast
           you can verify" / "Cited science. No hype." Strong half of
           each pillar is rendered with full text colour; the rest is
           muted so the eye scans the strong half first. -->
      <view class="login-pillars fade-in" style="animation-delay: 360ms">
        <view class="login-pillar">
          <text class="login-pillar-num">01</text>
          <view class="login-pillar-text">
            <text class="login-pillar-strong">{{tr.pillar1Strong}}</text>
            <text class="login-pillar-rest">{{tr.pillar1Rest}}</text>
          </view>
        </view>
        <view class="login-pillar">
          <text class="login-pillar-num">02</text>
          <view class="login-pillar-text">
            <text class="login-pillar-strong">{{tr.pillar2Strong}}</text>
            <text class="login-pillar-rest">{{tr.pillar2Rest}}</text>
          </view>
        </view>
        <view class="login-pillar">
          <text class="login-pillar-num">03</text>
          <view class="login-pillar-text">
            <text class="login-pillar-strong">{{tr.pillar3Strong}}</text>
            <text class="login-pillar-rest">{{tr.pillar3Rest}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- Footer: waitlist link + invitation-code-on-web hint. The
         waitlist replaces the prior "Sign up at praxys.run" copy-to-
         clipboard handoff for users without a code. Per CLAUDE.md
         registration boundary, the waitlist is the one registration-
         adjacent write the miniapp owns; invitation-code redemption
         + account creation + the platform-connection wizard all stay
         on praxys.run. -->
    <view class="login-footer fade-in" style="animation-delay: 440ms">
      <view class="login-footer-row" bindtap="onWaitlistTap">
        <text class="login-footer-label ts-muted">{{tr.newHere}}</text>
        <text class="login-footer-link">{{tr.joinTheWaitlist}}</text>
      </view>
      <view class="login-footer-block">
        <view class="login-footer-row" bindtap="onCopySignupUrl">
          <text class="login-footer-label ts-muted">{{tr.haveInviteCode}}</text>
          <text class="login-footer-link">{{tr.registerOnPraxys}}</text>
        </view>
        <!-- Helper line clarifies the two-step flow: invitation-code
             redemption + account creation + the platform-connection
             wizard happen on web, then the user returns here and binds
             that account to WeChat via the link-with-password path. -->
        <text class="login-footer-helper ts-muted">{{tr.thenSignInWithWeChat}}</text>
      </view>
    </view>
  </block>

  <block wx:elif="{{stage === 'loading'}}">
    <view class="login-stack">
      <image class="login-mark" src="/assets/brand/mark.png" mode="aspectFit" />
      <text class="login-hero">{{tr.signingIn}}</text>
    </view>
  </block>

  <block wx:elif="{{stage === 'error'}}">
    <view class="login-stack">
      <image class="login-mark" src="/assets/brand/mark.png" mode="aspectFit" />
      <text class="login-hero ts-destructive">{{tr.signInFailed}}</text>
      <text class="login-description">{{errorMessage}}</text>
      <button class="ts-button login-cta" bindtap="onRetry">{{tr.retry}}</button>
    </view>
  </block>

  <!-- Link form: WeChat is unbound on the backend. Same brand stack at
       top, then email + password inputs, then "Link to Praxys" CTA.
       The waitlist row stays accessible so a brand-new WeChat user
       who landed here by mistake can pivot without backing out. -->
  <block wx:elif="{{stage === 'choose' || stage === 'link'}}">
    <view class="login-stack">
      <image class="login-mark" src="/assets/brand/mark.png" mode="aspectFit" />
      <view class="login-wordmark">
        <text class="login-wordmark__text">Pra<text class="login-wordmark__accent">x</text>ys</text>
      </view>
      <text class="login-hero">{{tr.linkTitle}}</text>
      <text class="login-description">{{tr.linkDetail}}</text>
      <view class="login-field">
        <view class="login-field__icon login-field__icon--mail"></view>
        <input
          class="login-field__input"
          type="email"
          placeholder="{{tr.emailPlaceholder}}"
          placeholder-class="login-field__placeholder"
          style="color: {{themeClass === 'theme-light' ? '#15192a' : '#e8ebf0'}}; text-align: left;"
          cursor-spacing="{{40}}"
          adjust-position="{{true}}"
          confirm-type="next"
          value="{{linkEmail}}"
          bindinput="onLinkEmailInput"
        />
      </view>
      <view class="login-field">
        <view class="login-field__icon login-field__icon--lock"></view>
        <input
          class="login-field__input"
          password="{{true}}"
          placeholder="{{tr.passwordPlaceholder}}"
          placeholder-class="login-field__placeholder"
          style="color: {{themeClass === 'theme-light' ? '#15192a' : '#e8ebf0'}}; text-align: left;"
          cursor-spacing="{{40}}"
          adjust-position="{{true}}"
          confirm-type="done"
          value="{{linkPassword}}"
          bindinput="onLinkPasswordInput"
        />
      </view>
      <view class="login-agree" bindtap="onToggleAgree">
        <view class="login-agree-box {{agreedTerms ? 'login-agree-box--on' : ''}}">
          <text wx:if="{{agreedTerms}}" class="login-agree-tick">✓</text>
        </view>
        <view class="login-agree-text">
          <text class="login-agree-lead">{{tr.agreeLead}}</text>
          <text class="login-consent-link" data-kind="terms" catchtap="onOpenLegal">{{tr.termsName}}</text>
          <text class="login-consent-dot">·</text>
          <text class="login-consent-link" data-kind="privacy" catchtap="onOpenLegal">{{tr.privacyName}}</text>
        </view>
      </view>
      <text wx:if="{{linkError}}" class="login-error ts-destructive">{{linkError}}</text>
      <button
        class="ts-button login-cta"
        loading="{{linkSubmitting}}"
        bindtap="onLinkSubmit"
      >{{tr.linkAction}}</button>
    </view>
    <view class="login-footer">
      <view class="login-footer-row" bindtap="onWaitlistTap">
        <text class="login-footer-label ts-muted">{{tr.newHere}}</text>
        <text class="login-footer-link">{{tr.joinTheWaitlist}}</text>
      </view>
    </view>
  </block>

  <!-- Waitlist signup. Calls POST /api/auth/waitlist with
       { email, note?, locale }; per-IP rate-limited (5/hour) on the
       backend. Success state shows the same "we'll reach out from
       support@praxys.run when a slot opens" message web shows, then
       a back-to-idle button. -->
  <block wx:elif="{{stage === 'waitlist'}}">
    <view class="login-stack">
      <image class="login-mark" src="/assets/brand/mark.png" mode="aspectFit" />
      <view class="login-eyebrow">
        <view class="login-eyebrow-dot"></view>
        <text class="login-eyebrow-text">{{tr.alphaEyebrow}}</text>
      </view>
      <text class="login-hero">{{tr.joinTheWaitlist}}</text>
      <text class="login-description">{{tr.waitlistIntro}}</text>

      <view class="login-field">
        <view class="login-field__icon login-field__icon--mail"></view>
        <input
          class="login-field__input"
          type="email"
          placeholder="{{tr.emailPlaceholder}}"
          placeholder-class="login-field__placeholder"
          style="color: {{themeClass === 'theme-light' ? '#15192a' : '#e8ebf0'}}; text-align: left;"
          cursor-spacing="{{40}}"
          adjust-position="{{true}}"
          confirm-type="next"
          value="{{waitlistEmail}}"
          bindinput="onWaitlistEmailInput"
        />
      </view>
      <view class="login-field">
        <view class="login-field__icon login-field__icon--note"></view>
        <input
          class="login-field__input"
          type="text"
          maxlength="{{500}}"
          placeholder="{{tr.waitlistNotePlaceholder}}"
          placeholder-class="login-field__placeholder"
          style="color: {{themeClass === 'theme-light' ? '#15192a' : '#e8ebf0'}}; text-align: left;"
          cursor-spacing="{{40}}"
          adjust-position="{{true}}"
          confirm-type="done"
          value="{{waitlistNote}}"
          bindinput="onWaitlistNoteInput"
        />
      </view>
      <view class="login-agree" bindtap="onToggleAgree">
        <view class="login-agree-box {{agreedTerms ? 'login-agree-box--on' : ''}}">
          <text wx:if="{{agreedTerms}}" class="login-agree-tick">✓</text>
        </view>
        <view class="login-agree-text">
          <text class="login-agree-lead">{{tr.agreeLead}}</text>
          <text class="login-consent-link" data-kind="terms" catchtap="onOpenLegal">{{tr.termsName}}</text>
          <text class="login-consent-dot">·</text>
          <text class="login-consent-link" data-kind="privacy" catchtap="onOpenLegal">{{tr.privacyName}}</text>
        </view>
      </view>
      <text wx:if="{{waitlistError}}" class="login-error ts-destructive">{{waitlistError}}</text>
      <button
        class="ts-button login-cta"
        loading="{{waitlistSubmitting}}"
        bindtap="onWaitlistSubmit"
      >{{waitlistSubmitting ? tr.saving : tr.joinTheWaitlist}}</button>
      <view class="login-back-row" bindtap="onWaitlistBack">
        <text class="login-back-link ts-muted">{{tr.backToSignIn}}</text>
      </view>
    </view>
  </block>

  <block wx:elif="{{stage === 'waitlist-success'}}">
    <view class="login-stack">
      <image class="login-mark" src="/assets/brand/mark.png" mode="aspectFit" />
      <view class="login-success">
        <text class="login-success-mark">✓</text>
        <text class="login-success-title">{{tr.waitlistSuccessTitle}}</text>
      </view>
      <text class="login-description">{{tr.waitlistSuccessDetail}}</text>
      <button class="ts-button login-cta" bindtap="onWaitlistBack">{{tr.backToSignIn}}</button>
    </view>
  </block>
</view>
