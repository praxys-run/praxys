<view wx:if="{{visible}}" class="decision-check {{submitted ? 'decision-check--thanks' : ''}}">
  <block wx:if="{{submitted}}">
    <text class="decision-check__eyebrow font-data">{{tr.eyebrow}}</text>
    <text class="decision-check__thanks" role="status">{{tr.thanks}}</text>
  </block>
  <block wx:else>
    <view class="decision-check__copy">
      <text class="decision-check__eyebrow font-data">{{tr.eyebrow}}</text>
      <text class="decision-check__heading">{{tr.heading}}</text>
      <text class="decision-check__detail">{{tr.detail}}</text>
    </view>
    <view class="decision-check__options">
      <button
        wx:for="{{options}}"
        wx:key="value"
        class="decision-check__option"
        data-response="{{item.value}}"
        disabled="{{submitting}}"
        bindtap="onResponse"
      >{{item.label}}</button>
      <text wx:if="{{submitError}}" class="decision-check__error" role="alert">{{submitError}}</text>
    </view>
    <button
      class="decision-check__dismiss"
      aria-label="{{tr.dismiss}}"
      disabled="{{submitting}}"
      bindtap="onDismiss"
    >×</button>
  </block>
</view>
