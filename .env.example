# Praxys Server Configuration
# Copy this file to .env and fill in your values.
# Generate a Fernet key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#
# Migration note: legacy TRAINSIGHT_* env vars are still read for backward
# compatibility and will be removed after 2026-05-19. Prefer PRAXYS_* for
# all new deployments.

# Required: Encryption key for platform credentials (Garmin/Stryd/Oura passwords)
# Without this, credentials won't survive server restarts.
PRAXYS_LOCAL_ENCRYPTION_KEY=

# JWT secret for auth tokens.
#   The app refuses to boot in any environment that isn't explicitly marked
#   as dev. Set PRAXYS_ENV=development for local work without a secret (a
#   random per-process secret is generated; reloads invalidate sessions),
#   or provide an explicit value here / in App Service configuration.
#   Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
# PRAXYS_JWT_SECRET=
# PRAXYS_ENV=development

# Optional: Admin email — this email can register without an invitation code
# and is always granted admin privileges. Not needed if you're the first user.
# PRAXYS_ADMIN_EMAIL=

# Optional: Authentication rate limiter (api/auth_rate_limit.py).
#   Caps per-IP attempts on /api/auth/login, /api/auth/register, and the
#   /api/auth/wechat/* endpoints. Enabled by default in any deployment.
#   Set to "true" to disable for tests / local development. Adjust
#   PRAXYS_TRUSTED_PROXY_HOPS when you have multiple reverse proxies in
#   front of the app (default 1 = trust the rightmost X-Forwarded-For
#   entry, which is correct for a vanilla Azure App Service deployment).
# PRAXYS_AUTH_RATE_LIMIT_DISABLED=false
# PRAXYS_TRUSTED_PROXY_HOPS=1

# Optional: Strava OAuth app credentials for browser-based Strava connect.
# Activities-only sync uses these to exchange and refresh tokens.
# Register the callback URL shown below in your Strava app settings.
# PRAXYS_STRAVA_CLIENT_ID=
# PRAXYS_STRAVA_CLIENT_SECRET=

# Optional: Override the callback URL used in the Strava OAuth flow.
# Leave unset in local dev to use the app's detected callback route.
# PRAXYS_STRAVA_REDIRECT_URI=https://your-api.example.com/api/settings/connections/strava/callback

# Optional: Azure Application Insights connection string for production
# observability (traces, metrics, logs). When set, the app auto-ships
# per-request timings + DB dependency spans + Python logs to the
# configured App Insights resource. Leave unset locally — app runs fine
# without it. Copy from the "Connection String" field on the Overview
# blade of your Application Insights resource in the Azure portal.
#
# On Azure App Service, the server authenticates to App Insights via the
# App Service's system-assigned managed identity (no secret in app
# settings); the connection string is only used for routing. The MI must
# hold the "Monitoring Metrics Publisher" role on the AI resource — see
# docs/perf-baselines/azure-provisioning.md.
# APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...;IngestionEndpoint=...

# Optional: Azure OpenAI for LLM-generated bilingual insights (post-sync
# daily_brief / training_review / race_forecast). Auth uses
# DefaultAzureCredential (no API key); the same scaffolding powers the i18n
# translation pipeline in scripts/translate_missing.py.
#
# Leave AZURE_AI_ENDPOINT unset to disable LLM insights — the app falls back
# to the rule-based prose in analysis/metrics.py.
#
# AZURE_AI_ENDPOINT=https://<resource>.cognitiveservices.azure.com/
# PRAXYS_INSIGHT_MODEL=gpt-5.4              # reasoning model deployment for insights
# TRANSLATE_MODEL=gpt-5.4-mini              # smaller model for i18n translation
# AZURE_OPENAI_API_VERSION=2025-04-01-preview
# PRAXYS_INSIGHT_DAILY_CAP=30               # max LLM generations per user per UTC day

# Optional: In-app feedback → GitHub issue auto-filing.
# When a user submits feedback (bug / feature / other) from the web app or
# WeChat mini program, it's stored in the DB and a background task PII-scrubs
# + (optionally) AI-classifies it, then opens a GitHub issue so an agent can
# triage / fix it. If these are unset, feedback is still captured and an admin
# can promote it manually from the Admin page — only the auto-issue step is
# skipped.
#
# Recommended target: the SAME repo as the code (e.g. dddtc2005/praxys) so the
# GitHub Copilot coding agent assigned the issue can open a fix PR in-repo.
#
# Auth uses a GitHub App (no token to rotate): the backend mints short-lived
# installation tokens on demand and caches them. The app needs "Issues: write"
# on the repo; the PEM private key may be stored single-line with \n escapes.
# Setup: docs/ops/setup-github-app.md
# PRAXYS_GITHUB_APP_ID=
# PRAXYS_GITHUB_APP_INSTALLATION_ID=
# PRAXYS_GITHUB_APP_PRIVATE_KEY=
# PRAXYS_FEEDBACK_GITHUB_REPO=dddtc2005/praxys
#
# SECURITY: this repo is PUBLIC, so two layers protect against leaks before an
# issue is filed: (1) a deterministic PII/secret scrub on everything published,
# and (2) an AI "sensitivity gate" — if the model judges a (scrubbed) report
# still risks personal / health / credential content, it is NOT auto-filed; it
# is parked as "needs_review" for an admin to approve from the Admin page.
# Reports where the scrubber caught a key/token are always parked. Prefer total
# privacy instead? Point the repo above at a PRIVATE one — but note an agent
# there can't open PRs against the public code repo.
#
# When Azure OpenAI is NOT configured there is no AI gate, so by default nothing
# auto-files to the public repo (everything is parked for admin review). Set
# this to true to allow scrub-only auto-filing without the AI gate (you accept
# the residual risk).
# PRAXYS_FEEDBACK_AUTOFILE_WITHOUT_AI=false
#
# Comma-separated labels added to every filed issue (e.g. a label your coding
# agent automation watches so it auto-picks-up the issue). Optional.
# PRAXYS_FEEDBACK_GITHUB_LABELS=
# Comma-separated GitHub logins to assign (e.g. the Copilot coding-agent bot
# once enabled on the repo). Optional.
# PRAXYS_FEEDBACK_GITHUB_ASSIGNEES=
#
# Admin notification: parked (needs_review) reports show as a badge on the
# Admin sidebar. To also EMAIL admins, wire an Azure Monitor alert on the
# praxys.feedback metric (status=needs_review) — no app code needed. Steps +
# KQL: docs/ops/monitoring-and-alerts.md